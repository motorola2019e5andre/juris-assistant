{
  "manifest_version": 3,
  "name": "Juris Assistant",
  "version": "1.0.0",
  "description": "Assistente jurídico para resumo de processos",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3333/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Juris Assistant"
  }
}