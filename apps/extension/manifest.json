{
  "manifest_version": 3,
  "name": "Juris Assistant",
  "version": "1.1",
  "description": "Assistente jurídico com IA",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Juris Assistant"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}