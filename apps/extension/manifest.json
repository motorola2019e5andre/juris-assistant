{
  "manifest_version": 3,
  "name": "Juris Assistant",
  "version": "2.0.0",
  "description": "Assistente juridico com IA",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "http://localhost:3333/*",
    "https://juris-assistant-api.onrender.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Juris Assistant"
  }
}