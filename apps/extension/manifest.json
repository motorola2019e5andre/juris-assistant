{
  "manifest_version": 3,
  "name": "Juris Assistant",
  "version": "1.0.0",
  "description": "Assistente jurídico com IA para TRT, TRF e EPROC",
  "permissions": ["storage", "sidePanel", "activeTab", "scripting"],
  "host_permissions": [
    "https://juris-assistant-api.onrender.com/",
    "https://*.trt.jus.br/*",
    "https://*.trf.jus.br/*"
  ],
  "action": {
    "default_title": "Juris Assistant",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.trt.jus.br/*",
        "https://*.trf.jus.br/*"
      ],
      "js": ["content.js"]
    }
  ]
}